<style>
	.footer {
		margin-top: 5rem;
		padding: 2rem 1.25rem 1.5rem;
		border-top: 1px solid rgba(255,255,255,0.06);
	}

	.footer-inner {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.webring-row {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 1rem;
	}

	.ring-icons {
		display: flex;
		gap: 0.75rem;
		align-items: center;
	}

	.ring-icon-wrap {
		display: flex;
		align-items: center;
		opacity: 0.6;
		transition: opacity 0.2s;
	}

	.ring-icon-wrap:hover {
		opacity: 1;
	}

	.ring-icon-wrap img {
		width: 28px;
		height: 28px;
		object-fit: contain;
	}

	.footer-divider {
		height: 1px;
		background: rgba(255,255,255,0.05);
	}

	.footer-credit {
		text-align: center;
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}

	.footer-credit p {
		font-size: 0.88rem;
		color: #64748b;
		margin: 0;
	}

	.footer-credit strong {
		color: #94a3b8;
		font-weight: 600;
	}

	.footer-sub {
		font-size: 0.82rem !important;
	}

	.footer-link {
		color: #f97316;
		text-decoration: none;
		font-weight: 600;
		transition: opacity 0.2s;
	}

	.footer-link:hover {
		opacity: 0.7;
	}
</style>
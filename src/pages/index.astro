---
import PageLayout from "../layouts/PageLayout.astro"
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import * as data from "../consts"
import Education from "../components/About/Education.astro";
import InfoAndConnect from "../components/About/InfoAndConnect.astro";
import Events from "../components/About/Events.astro"
import Projects from "../components/About/Projects.astro"
import TechAndInterests from "../components/About/TechAndInterests.astro"
---

<PageLayout title={SITE_TITLE} description={SITE_DESCRIPTION}>
    <div class="hero-section">
        <div class="hero-bg">
            <div class="hero-blob blob-1"></div>
            <div class="hero-blob blob-2"></div>
            <div class="hero-blob blob-3"></div>
        </div>
        <div class="hero-content">
            <img src="/bowling.png" class="hero-avatar" alt={data.about.name} />
            <div class="hero-text">
                <h1 class="hero-name">
                    {data.about.name.split(" ")[0]}<br/>
                    <span class="hero-name-accent">{data.about.name.split(" ")[1]}</span>
                </h1>
                <p class="hero-aka">aka <strong>{data.about.aka}</strong> · {data.about.loc}</p>
                <p class="hero-desc">{data.about.desc}</p>
                <div class="hero-cta">
                    <a href="#projects" class="btn-primary-hero">View Projects</a>
                    <a href="#connect" class="btn-ghost-hero">Get in Touch</a>
                </div>
            </div>
        </div>
    </div>

    <main class="main-content">
        <InfoAndConnect data={data} />
        <Education data={data} />
        <Events data={data} />
        <Projects data={data} />
        <TechAndInterests data={data} />
    </main>
</PageLayout>

<style>
    .hero-section {
        position: relative;
        overflow: hidden;
        border-radius: 24px;
        background: linear-gradient(135deg, #0f0f14 0%, #1a1025 50%, #0d1a24 100%);
        padding: 3rem 2rem;
        margin-bottom: 4rem;
        border: 1px solid rgba(255,255,255,0.06);
    }

    .hero-bg {
        position: absolute;
        inset: 0;
        pointer-events: none;
    }

    .hero-blob {
        position: absolute;
        border-radius: 50%;
        filter: blur(80px);
        opacity: 0.35;
    }

    .blob-1 {
        width: 400px; height: 400px;
        background: radial-gradient(circle, #f97316 0%, transparent 70%);
        top: -100px; left: -100px;
    }

    .blob-2 {
        width: 300px; height: 300px;
        background: radial-gradient(circle, #db2777 0%, transparent 70%);
        top: 50%; right: -80px;
        transform: translateY(-50%);
    }

    .blob-3 {
        width: 250px; height: 250px;
        background: radial-gradient(circle, #7c3aed 0%, transparent 70%);
        bottom: -60px; left: 40%;
    }

    .hero-content {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2rem;
    }

    @media (min-width: 768px) {
        .hero-content {
            flex-direction: row;
            align-items: center;
        }
    }

    .hero-avatar {
        width: 220px;
        height: 220px;
        object-fit: cover;
        border-radius: 50%;
        border: 3px solid rgba(249,115,22,0.5);
        box-shadow: 0 0 40px rgba(249,115,22,0.2), 0 20px 60px rgba(0,0,0,0.5);
        flex-shrink: 0;
        animation: float 6s ease-in-out infinite;
    }

    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    .hero-text {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.3rem 0.9rem;
        background: rgba(249,115,22,0.15);
        border: 1px solid rgba(249,115,22,0.4);
        border-radius: 100px;
        font-size: 0.75rem;
        font-weight: 600;
        color: #fb923c;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        width: fit-content;
    }

    .hero-badge::before {
        content: '';
        width: 6px; height: 6px;
        border-radius: 50%;
        background: #4ade80;
        animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.5; transform: scale(0.8); }
    }

    .hero-name {
        font-size: clamp(2.5rem, 6vw, 4.5rem);
        font-weight: 900;
        line-height: 1;
        color: #f8fafc;
        letter-spacing: -0.02em;
        margin: 0;
    }

    .hero-name-accent {
        background: linear-gradient(135deg, #f97316, #db2777);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-aka {
        font-size: 0.95rem;
        color: #94a3b8;
        margin: 0;
    }

    .hero-desc {
        font-size: 1rem;
        color: #cbd5e1;
        line-height: 1.7;
        max-width: 540px;
        margin: 0;
    }

    .hero-cta {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
        margin-top: 0.5rem;
    }

    .btn-primary-hero {
        padding: 0.7rem 1.6rem;
        background: linear-gradient(135deg, #f97316, #db2777);
        color: white;
        border-radius: 10px;
        font-weight: 700;
        font-size: 0.9rem;
        text-decoration: none;
        transition: opacity 0.2s, transform 0.2s;
    }

    .btn-primary-hero:hover {
        opacity: 0.9;
        transform: translateY(-2px);
    }

    .btn-ghost-hero {
        padding: 0.7rem 1.6rem;
        background: rgba(255,255,255,0.05);
        color: #e2e8f0;
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.9rem;
        text-decoration: none;
        transition: background 0.2s, transform 0.2s;
    }

    .btn-ghost-hero:hover {
        background: rgba(255,255,255,0.1);
        transform: translateY(-2px);
    }

    .main-content {
        display: flex;
        flex-direction: column;
        gap: 5rem;
    }
</style>